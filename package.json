{
  "name": "pos-system",
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "start": "node server.js",
    "electron": "cross-env NODE_ENV=development electron .",
    "build:frontend": "cd frontend && npm run build",
    "prepack": "npm run build:frontend",
    "dist": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "ipp": "^1.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sweetalert2": "^11.26.24",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.tusistema.pos",
    "productName": "Sistema POS",
    "directories": {
      "output": "installer_output"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "server.js",
      "src/**/*",
      "frontend/dist/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
