# Backend Configuration Example
NODE_ENV=development
PORT=3000
VITE_API_URL=http://localhost:3000

# Database Configuration - IMPORTANT: Update with your PostgreSQL credentials
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_db

# JWT Configuration - Generate a secure random string
JWT_SECRET=tu_jwt_secret_key_super_seguro_2024_almacen_pos
JWT_EXPIRE=7d

# License Configuration
LICENSE_SECRET=POS_LICENSE_SECRET_KEY_2024_ALMACEN

# Two Factor Authentication
TWOFACTOR_ISSUER=ALMACEN-POS

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./public/uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Session Configuration
SESSION_SECRET=session_secret_key_almacen_pos_2024

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Security - CORS origins allowed to connect
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
